ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin User

# Optional custom DB file path. Defaults to ./data/lib-app.sqlite locally.
# SQLITE_DB_PATH=/absolute/path/to/lib-app.sqlite

# SMTP settings for email login codes.
# If omitted, login codes are printed to server logs in development.
# Optional fallback: when SMTP is missing/rejected, display code in login success message.
# Set to false to disable plaintext fallback.
# ALLOW_PLAINTEXT_LOGIN_CODE_FALLBACK=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=mailer@example.com
# SMTP_PASS=your-password
# SMTP_FROM="Library App <mailer@example.com>"
